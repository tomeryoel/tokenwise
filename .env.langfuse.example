# Copy this file to .env.langfuse and replace every CHANGE_ME value.
# Use long random hexadecimal strings so URI-based service credentials remain safe.

LANGFUSE_TRACING_ENABLED=true
LANGFUSE_FLUSH_ON_EXPORT=true
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=tokenwise-day-9
LANGFUSE_PUBLIC_URL=http://localhost:3000

# Project API keys used by both headless initialization and optimizer-service.
LANGFUSE_PUBLIC_KEY=lf_pk_CHANGE_ME
LANGFUSE_SECRET_KEY=lf_sk_CHANGE_ME

# Local Langfuse login created on first startup.
LANGFUSE_INIT_USER_EMAIL=tomer@tokenwise.local
LANGFUSE_INIT_USER_NAME=Tomer
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME

# Self-hosted infrastructure secrets. Never reuse these outside local development.
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARACTERS
LANGFUSE_POSTGRES_PASSWORD=CHANGE_ME
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGE_ME
LANGFUSE_REDIS_AUTH=CHANGE_ME
LANGFUSE_MINIO_ROOT_USER=tokenwise-minio
LANGFUSE_MINIO_ROOT_PASSWORD=CHANGE_ME
