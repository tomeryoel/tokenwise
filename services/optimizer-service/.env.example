# MomiHelm optimizer-service environment (placeholders only - never commit real secrets)
# Copy to .env and fill in values for local development outside Docker.

# --- Ollama (local provider) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LOCAL_MODEL=llama3.1:latest
OLLAMA_CHEAP_MODEL=llama3.1:latest
OLLAMA_BALANCED_MODEL=llama3.1:latest
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# --- OpenAI (optional external provider) ---
ENABLE_OPENAI_PROVIDER=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHEAP_MODEL=
OPENAI_BALANCED_MODEL=
OPENAI_PREMIUM_MODEL=
OPENAI_REQUEST_TIMEOUT_SECONDS=60

# --- Pricing ---
MODEL_PRICING_CONFIG_PATH=/app/config/model_pricing.json

# --- Usage database (Day 7) ---
USAGE_DB_PATH=/app/data/usage/tokenwise.db
