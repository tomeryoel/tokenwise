# MomiHelm local runtime configuration.
# Copy this file to .env, then adjust only the provider section you use.

# Bind services to this machine only. Change deliberately for remote deployment.
MOMIHELM_HOST=127.0.0.1
MOMIHELM_FRONTEND_PORT=5173

# Browser authentication. Keep COOKIE_SECURE=false for local HTTP; set it to
# true when MomiHelm is served through HTTPS.
MOMIHELM_SESSION_TTL_HOURS=12
MOMIHELM_COOKIE_SECURE=false
MOMIHELM_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MOMIHELM_MAX_PROMPT_CHARS=100000
MOMIHELM_MAX_IMAGE_BASE64_CHARS=7000000

# Local Ollama provider. Install Ollama separately and pull the configured model.
# OLLAMA_HOST_URL is used by the host-side doctor command.
OLLAMA_HOST_URL=http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LOCAL_MODEL=llama3.1:latest
OLLAMA_CHEAP_MODEL=llama3.1:latest
OLLAMA_BALANCED_MODEL=llama3.1:latest
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# Optional OpenAI provider. Keep disabled when using only local Ollama.
ENABLE_OPENAI_PROVIDER=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHEAP_MODEL=
OPENAI_BALANCED_MODEL=
OPENAI_PREMIUM_MODEL=
OPENAI_REQUEST_TIMEOUT_SECONDS=60

# Stable n8n version validated with the bundled workflows.
N8N_VERSION=2.31.5
